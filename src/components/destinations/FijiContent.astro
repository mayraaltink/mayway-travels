---
import DestinationContent from "./DestinationContent.astro";
import { ui, defaultLang } from '../../i18n/ui';

// Get current language
const currentPath = Astro.url.pathname;
const lang = (Astro.currentLocale || (currentPath.startsWith('/en') ? 'en' : defaultLang)) as keyof typeof ui;

// Translation helper
function t(key: keyof typeof ui[typeof lang]) {
  return ui[lang][key];
}
---

<DestinationContent
  title={t('Fiji.page.title')}
  description={t('Fiji.page.desc')}
  capital={t('Fiji.page.capital')}
  language={t('Fiji.page.language')}
  currency={t('Fiji.page.currency')}
imageSrc="/images/fiji/fiji_main.jpg"
imageAlt="Beautiful landscape in Fiji"
  planUrl={lang === 'nl'
  ? '/nl/route-planner?country=fiji'
  : '/en/route-planner?country=fiji'}
  guideUrl={lang === 'nl' ? '/eguides/' : '/en/eguides/'}
>
</DestinationContent>