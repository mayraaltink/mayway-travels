---
import DestinationContent from "./DestinationContent.astro";
import HotspotCarousel from './HotspotCarousel.astro';
import AustraliaRoutes from './AustraliaRoutes.astro';
import FaqAustralia from './FaqAustralia.astro';
import WorkingHoliday from './WorkingHoliday.astro';
import Reisdownunder from './Reisdownunder.astro';
import { ui, defaultLang } from '../../i18n/ui';

// Get current language
const currentPath = Astro.url.pathname;
const lang = (Astro.currentLocale || (currentPath.startsWith('/en') ? 'en' : defaultLang)) as keyof typeof ui;

// Translation helper
function t(key: keyof typeof ui[typeof lang]) {
  return ui[lang][key];
}
---

<DestinationContent
  title={t('aus.page.title')}
  description={t('aus.page.desc')}
  capital={t('aus.page.capital')}
  language={t('aus.page.language')}
  currency={t('aus.page.currency')}
  flightTime={t('aus.page.flightTime')}
  imageSrc="/images/australia/aus_main.jpg"
  imageAlt="Beautiful landscape in Australia"
  planUrl={lang === 'nl' ? '/nl/route-planner?country=australia' : '/en/route-planner?country=australia'}
  guideUrl={lang === 'nl' ? '/eguides/' : '/en/eguides/'}
>
  <!-- The carousel gets injected into the <slot /> of DestinationContent -->
   <Reisdownunder />
      <AustraliaRoutes />
  <HotspotCarousel />
  <WorkingHoliday />
    <FaqAustralia />
</DestinationContent>