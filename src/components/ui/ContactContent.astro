---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ui, defaultLang } from '../../i18n/ui';

const lang = Astro.currentLocale || defaultLang;

function t(key: keyof typeof ui[typeof defaultLang]) {
  return ui[lang as keyof typeof ui][key];
}
---

<BaseLayout title={t('contact.title')}>
  <div class="bg-[#F7F4EF] relative z-0 flex-grow pt-28 md:pt-36 pb-20 px-6">
    
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-[1fr_1.2fr] gap-12 md:gap-20 items-start">
      
      <!-- Left Side: Info & CTA -->
      <div class="flex flex-col justify-center">
      <h1 class="text-4xl md:text-5xl font-semibold text-gray-900 leading-[0.95] mb-6">
  {t('contact.heading')}
</h1>
        <p class="text-lg text-gray-600 mb-10 max-w-md leading-relaxed">
          {t('contact.intro')}
        </p>
        
        <div class="bg-white p-8 rounded-3xl shadow-sm border border-[#4ED2CE]/20 mb-10">
          <h3 class="text-xl font-bold text-gray-900 mb-2">{t('contact.intake.title')}</h3>
          <p class="text-gray-600 mb-6">{t('contact.intake.desc')}</p>
         <a 
  href="https://calendly.com/maywaytravels1/intake" 
  target="_blank"
  class="inline-block bg-[#4ED2CE] hover:bg-[#1CABB0] text-white px-7 py-3 rounded-full font-bold text-sm uppercase tracking-wider transition-all shadow-[0_4px_15px_rgba(78,210,206,0.3)] hover:shadow-[0_6px_20px_rgba(78,210,206,0.4)] hover:-translate-y-0.5"
>
  {t('contact.intake.btn')}
</a>
        </div>

        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-3">
  <span class="text-[#4ED2CE] font-bold text-md uppercase tracking-wider">
    E-mail
  </span>

<a
  href="https://mail.google.com/mail/?view=cm&fs=1&to=maywaytravels1@gmail.com"
  target="_blank"
  class="font-medium text-gray-800 text-lg hover:text-[#4ED2CE] transition-colors"
>
  maywaytravels1@gmail.com
</a>
</div>
          <div class="flex items-center gap-3">
  <span class="text-[#4ED2CE] font-bold text-md uppercase tracking-wider">
    Instagram
  </span>

  <a 
    href="https://instagram.com/maywaytravels"
    target="_blank"
    rel="noopener noreferrer"
    class="font-medium text-gray-800 text-lg hover:text-[#4ED2CE] transition-colors"
  >
    @maywaytravels
  </a>
</div>
        </div>
      </div>

      <!-- Right Side: Contact Form -->
      <div class="bg-white p-8 md:p-12 rounded-[2rem] shadow-[0_20px_50px_rgba(0,0,0,0.06)] relative">
        
        <form 
          action="https://api.web3forms.com/submit" 
          method="POST" 
          id="form" 
          class="needs-validation" 
          novalidate
        >
          <!-- Web3Forms Access Key -->
          <input type="hidden" name="access_key" value="026a1614-327e-4e4b-bdb4-d41e59fe8520" />
          
          <!-- Web3Forms Honeypot (Spam Protection) -->
          <input type="checkbox" class="hidden" style="display:none" name="botcheck" />
          
          <!-- Optional: Sets the subject of the email you receive -->
          <input type="hidden" name="subject" value="New Contact Message from May Way Travels" />

          <div class="mb-6">
            <label for="naam" class="block text-lg font-bold uppercase tracking-wider mb-2 text-gray-900">{t('contact.form.nameLabel')}</label>
            <input type="text" id="naam" name="naam" placeholder={t('contact.form.namePlaceholder')} required class="w-full p-4 border border-gray-200 rounded-xl bg-gray-50 focus:outline-none focus:border-[#4ED2CE] focus:bg-white transition-colors">
          </div>

          <div class="mb-6">
            <label for="email" class="block text-lg font-bold uppercase tracking-wider mb-2 text-gray-900">{t('contact.form.emailLabel')}</label>
            <input type="email" id="email" name="email" placeholder={t('contact.form.emailPlaceholder')} required class="w-full p-4 border border-gray-200 rounded-xl bg-gray-50 focus:outline-none focus:border-[#4ED2CE] focus:bg-white transition-colors">
          </div>

          <div class="mb-6">
            <label for="onderwerp" class="block text-lg font-bold uppercase tracking-wider mb-2 text-gray-900">{t('contact.form.subjectLabel')}</label>
            <input type="text" id="onderwerp" name="onderwerp" placeholder={t('contact.form.subjectPlaceholder')} class="w-full p-4 border border-gray-200 rounded-xl bg-gray-50 focus:outline-none focus:border-[#4ED2CE] focus:bg-white transition-colors">
          </div>

          <div class="mb-8 relative">
            <label for="bericht" class="block text-lg font-bold uppercase tracking-wider mb-2 text-gray-900">{t('contact.form.messageLabel')}</label>
            <textarea id="bericht" name="bericht" rows="4" placeholder={t('contact.form.messagePlaceholder')} required class="w-full p-4 border border-gray-200 rounded-xl bg-gray-50 focus:outline-none focus:border-[#4ED2CE] focus:bg-white transition-colors"></textarea>
          </div>

          <!-- Submit Button -->
          <button id="submit-btn" type="submit" class="w-full flex items-center justify-center gap-3 bg-gray-900 hover:bg-[#1CABB0] text-white p-4 rounded-xl font-bold transition-all text-lg disabled:opacity-70 disabled:cursor-not-allowed">
            <span id="submit-text">{t('contact.form.submit')}</span>
            <!-- Loading Spinner (Hidden by default) -->
            <svg id="submit-spinner" class="hidden animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </button>
          
        </form>

        <!-- New Clear Notification Alert Box -->
        <div id="notification-box" class="hidden mt-6 p-5 rounded-xl border flex items-start gap-4 transition-all duration-300">
          <div id="notify-icon" class="flex-shrink-0 mt-0.5"></div>
          <div>
            <h4 id="notify-title" class="font-bold text-lg mb-1"></h4>
            <p id="notify-desc" class="text-gray-700 text-sm leading-relaxed"></p>
          </div>
        </div>

      </div>

    </div>
  </div>
</BaseLayout>

<style>
  /* Form Validation Styles */
  .invalid-feedback,
  .empty-feedback {
    display: none;
  }
  
  .was-validated :placeholder-shown:invalid ~ .empty-feedback {
    display: block;
  }
  
  .was-validated :not(:placeholder-shown):invalid ~ .invalid-feedback {
    display: block;
  }
  
  .is-invalid,
  .was-validated :invalid {
    border-color: #dc3545;
  }
</style>

<script is:inline>
  function setupContactForm() {
    const form = document.getElementById("form");
    const submitBtn = document.getElementById("submit-btn");
    const submitText = document.getElementById("submit-text");
    const submitSpinner = document.getElementById("submit-spinner");
    const notificationBox = document.getElementById("notification-box");
    const notifyIcon = document.getElementById("notify-icon");
    const notifyTitle = document.getElementById("notify-title");
    const notifyDesc = document.getElementById("notify-desc");

    if (!form) return;

    // Remove old event listener if it exists (Astro View Transitions fix)
    const newForm = form.cloneNode(true);
    form.parentNode.replaceChild(newForm, form);
    const updatedForm = document.getElementById("form");

    // Icons for notifications
    const iconSuccess = `<svg class="w-7 h-7 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`;
    const iconError = `<svg class="w-7 h-7 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`;

    // Store original button text
    const originalBtnText = submitText.innerText;

    updatedForm.addEventListener("submit", function (e) {
      e.preventDefault();
      updatedForm.classList.add("was-validated");
      
      if (!updatedForm.checkValidity()) {
        updatedForm.querySelectorAll(":invalid")[0].focus();
        return;
      }

      // 1. UI Loading State
      submitBtn.disabled = true;
      submitText.innerText = "Sending...";
      submitSpinner.classList.remove("hidden");
      notificationBox.classList.add("hidden"); // Hide previous alerts
      
      const formData = new FormData(updatedForm);
      const object = Object.fromEntries(formData);
      const json = JSON.stringify(object);

      fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: json,
      })
      .then(async (response) => {
        let json = await response.json();
        
        // Remove hidden to show the box
        notificationBox.classList.remove("hidden");

        if (response.status == 200) {
          // Success State
          notificationBox.className = "mt-6 p-5 rounded-xl border bg-green-50 border-green-200 flex items-start gap-4 transition-all duration-300";
          notifyIcon.innerHTML = iconSuccess;
          notifyTitle.innerText = "Message Sent!";
          notifyTitle.className = "font-bold text-lg mb-1 text-green-900";
          notifyDesc.innerText = "Thank you for getting in touch. We will get back to you as soon as possible.";
          
          updatedForm.reset();
          updatedForm.classList.remove("was-validated");
        } else {
          // Error State
          console.log(response);
          notificationBox.className = "mt-6 p-5 rounded-xl border bg-red-50 border-red-200 flex items-start gap-4 transition-all duration-300";
          notifyIcon.innerHTML = iconError;
          notifyTitle.innerText = "Oops! Something went wrong.";
          notifyTitle.className = "font-bold text-lg mb-1 text-red-900";
          notifyDesc.innerText = json.message || "Please try again later or contact us directly via email.";
        }
      })
      .catch((error) => {
        console.log(error);
        notificationBox.classList.remove("hidden");
        notificationBox.className = "mt-6 p-5 rounded-xl border bg-red-50 border-red-200 flex items-start gap-4 transition-all duration-300";
        notifyIcon.innerHTML = iconError;
        notifyTitle.innerText = "Connection Error";
        notifyTitle.className = "font-bold text-lg mb-1 text-red-900";
        notifyDesc.innerText = "Please check your internet connection and try again.";
      })
      .finally(function () {
        // Revert button back to normal state
        submitBtn.disabled = false;
        submitText.innerText = originalBtnText;
        submitSpinner.classList.add("hidden");
      });
    });
  }

  // Run on standard load
  document.addEventListener("DOMContentLoaded", setupContactForm);
  // Run on Astro page navigation (if ViewTransitions are enabled)
  document.addEventListener("astro:page-load", setupContactForm);
</script>