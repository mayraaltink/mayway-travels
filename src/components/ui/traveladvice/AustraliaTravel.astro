---
// src/components/ui/TravelAdviceContent.astro
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ui, defaultLang } from '../../../i18n/ui';


const lang = Astro.currentLocale || defaultLang;

function t(key: string) {
  const dict = ui[lang as keyof typeof ui] as Record<string, string>;
  return dict[key] ?? key;
}
---

<BaseLayout title={t('travelAdvice.title')}>
  <div class="bg-[#FFFDFA]">

  <section class="relative h-screen flex items-center justify-center overflow-hidden -mt-16 rounded-b-[80px]">
    

  <!-- GRADIENT OVERLAY -->
  <div class="absolute inset-0 bg-gradient-to-b from-gray-900/50 via-gray-900/30 to-transparent z-10"></div>

  <!-- BACKGROUND IMAGE -->
<img
  src="/images/travel-plan/Sydney.jpg"
  alt="Sydney travel"
  class="absolute inset-0 z-0 h-full w-full object-cover"
/>

  <!-- LOCATION (bottom left badge) -->
<div class="absolute bottom-6 left-6 flex items-center gap-2 rounded-full bg-black/35 px-4 py-2 text-sm text-white backdrop-blur-sm z-20">
  
  <!-- optional icon -->
  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white/90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
    <circle cx="12" cy="10" r="3"></circle>
  </svg>

  <span class="uppercase text-xs tracking-wide text-white/90">
    Australië · Sydney
  </span>

</div>

  <!-- CONTENT -->
  <div class="relative z-20 text-center text-white max-w-3xl px-6">

  

    <!-- title -->
    <h1 class="flex flex-col text-center leading-[0.80] tracking-[-0.03em]">

    <span class="text-xl md:text-4xl font-medium text-white">
    Persoonlijk reisplan
  </span>

 <span class="text-3xl md:text-7xl font-semibold text-white">
Australië </span>

</h1>

<!-- CTA'S (verplaatst) -->
<div class="mt-6 flex flex-col gap-4 sm:flex-row sm:justify-center sm:items-center">
  
  <!-- Primary CTA -->
  <a 
    href={`/${lang}/route-planner?country=australia`}
    class="inline-flex items-center gap-2 rounded-full bg-[#1CABB0] px-8 py-3 text-sm font-semibold text-white shadow-lg transition-all duration-300 hover:scale-105 hover:bg-[#15939a] hover:text-white"
  >
    {t('travelAdvice.hero.buybtn')}

    <svg 
      xmlns="http://www.w3.org/2000/svg" 
      width="18" 
      height="18" 
      viewBox="0 0 24 24" 
      fill="none" 
      stroke="currentColor" 
      stroke-width="2" 
      stroke-linecap="round" 
      stroke-linejoin="round"
      class="opacity-90"
    >
      <path d="M5 12h14"></path>
      <path d="m12 5 7 7-7 7"></path>
    </svg>
  </a>

  <!-- Secondary CTA -->
  <a 
    href="#features"
    class="inline-flex items-center gap-2 rounded-full border-2 border-white/60 px-8 py-3 text-sm font-semibold text-white transition-all duration-300 hover:bg-white/10 hover:border-white"
  >
    {t('travelAdvice.hero.previewbtn')}

    <svg 
      xmlns="http://www.w3.org/2000/svg" 
      width="18" 
      height="18" 
      viewBox="0 0 24 24" 
      fill="none" 
      stroke="currentColor" 
      stroke-width="2" 
      stroke-linecap="round" 
      stroke-linejoin="round"
      class="opacity-80"
    >
      <path d="M5 12h14"></path>
      <path d="m12 5 7 7-7 7"></path>
    </svg>
  </a>

</div>

</div>

  </div>

</section>

    <!-- Hero Section -->
    <section class="relative overflow-hidden pt-28 pb-16 md:pb-24">
      <div class="pointer-events-none absolute -right-24 top-24 h-96 w-96 rounded-full bg-[#4ED2CE]/10 blur-3xl"></div>
      <div class="pointer-events-none absolute -left-32 bottom-0 h-72 w-72 rounded-full bg-[#1CABB0]/10 blur-3xl"></div>
      
      <div class="relative mx-auto grid max-w-6xl items-center gap-12 px-6 lg:grid-cols-2 lg:gap-16">
        <div>
         
          <h1 class="text-3xl font-bold leading-tight text-gray-900 md:text-4xl lg:text-5xl">
            <span class="font-libre">{t('travelAdvice.hero.title1')}</span> 
          </h1>
        <div class="mt-6 max-w-xl text-lg leading-relaxed text-gray-600">

  <p class="font-semibold text-gray-900">
    {t('eguides.hero.descBold')}
  </p>

  <p class="mt-6">
    {t('eguides.hero.descNormal')}
  </p>

</div>
      
          
        </div>
        
        <div class="relative mx-auto w-full max-w-lg lg:mx-0 lg:max-w-none">
          <div class="absolute -right-2 -top-3 z-10 rotate-2 rounded-full bg-[#E6F6F6] px-4 py-2 text-xs font-bold uppercase tracking-wide text-[#1CABB0] shadow-lg">
            {t('travelAdvice.hero.badge2')}
          </div>
          <div class="relative overflow-hidden rounded-[1.75rem] bg-gradient-to-br from-[#E8FAF9] to-[#d4f3f1] p-4 shadow-2xl ring-1 ring-black/5">
            <div class="overflow-hidden rounded-2xl shadow-inner">
              <!-- Note: Change this src to the correct image in your public/images folder! -->
              <img src="/images/pexels-1320686.jpeg" alt="Interactive guide Australia" class="aspect-[4/3] w-full object-cover">
            </div>
            <div class="absolute bottom-5 left-5 rounded-2xl bg-white/95 px-4 py-3 shadow-lg backdrop-blur-sm">
              <p class="text-xs font-semibold uppercase tracking-wide text-[#1CABB0]">{t('travelAdvice.hero.included')}</p>
              <p class="text-lg font-bold text-gray-900">{t('travelAdvice.hero.modules')}</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    
 <!-- Features Section -->
<section id="features" class="bg-[#F4FBFB] py-20 md:py-28">

  <div class="mx-auto max-w-6xl px-6">

    <!-- GRID -->
    <div class="grid items-center gap-16 lg:grid-cols-2">

      <!-- LEFT: IMAGE -->
      <div class="relative">

        <!-- Main Card -->
        <div class="overflow-hidden rounded-[2rem] bg-white p-3 shadow-[0_20px_60px_rgba(0,0,0,0.15)] ring-1 ring-black/5 transition duration-500 hover:scale-[1.02]">

          <img
            src="/images/travel-plan/travelplan-preview.png"
            alt="Persoonlijk reisplan Australië"
            class="w-full rounded-2xl object-cover"
          />

        </div>

        

        <!-- Floating card -->
        <div
          class="absolute -bottom-6 -right-6 hidden md:block
                 rounded-2xl
                 bg-[#F4FBFB]
                 px-6 py-5
                 shadow-[0_20px_60px_rgba(0,0,0,0.18)]
                 ring-1 ring-[#E6F6F6]"
        >
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-[#1CABB0]">
            Preview reisplan
          </p>
        </div>

    
      </div>

   <!-- RIGHT: TEXT -->
<div>

  <h2 class="text-3xl font-bold text-gray-900 md:text-4xl">
    {t('travelAdvice.features.title')}
  </h2>

  <p class="mt-5 text-lg leading-relaxed text-gray-600">
    {t('travelAdvice.features.desc')}
  </p>

  <!-- FEATURES -->
  <div class="mt-8 space-y-3">

    {[1,2,3,4,5,6,7].map((num) => (
      <div class="flex items-start gap-4">

        <!-- Check -->
        <div class="mt-1 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-[#1CABB0]/10">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
               viewBox="0 0 24 24" fill="none" stroke="#1CABB0"
               stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6 9 17l-5-5"></path>
          </svg>
        </div>

        <!-- Text -->
        <p class="leading-relaxed text-gray-700">
          {t(`travelAdvice.features.${num}` as any)}
        </p>

      </div>
    ))}

  </div>

  <!-- CTA -->
<div class="mt-10 flex justify-center">

  <a
   <a
  href="/route-planner"
  class="inline-flex items-center gap-3
         rounded-full
        bg-[#1CABB0]/60
         px-7 py-3
         text-sm font-semibold text-white
         shadow-[0_18px_45px_rgba(28,171,176,0.25)]
         transition-all duration-300
         hover:scale-[1.04]
         hover:bg-[#15939a]
         hover:shadow-[0_25px_70px_rgba(28,171,176,0.35)]"
>
  <span>Start jouw avontuur</span>

  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M5 12h14"></path>
    <path d="m12 5 7 7-7 7"></path>
  </svg>
</a>

</div>

</div>

</section>




    <!-- Modules Section -->
   <section id="inhoud" class="scroll-mt-24 py-20 md:py-28 bg-[#FFFDFA]">
      <div class="mx-auto max-w-6xl px-6">
        <p class="text-center text-sm font-bold uppercase tracking-[0.2em] text-[#1CABB0]">{t('eguides.modules.badge')}</p>
        <h2 class="mt-2 text-center font-libre text-3xl font-bold text-gray-900 md:text-4xl">{t('eguides.modules.title')}</h2>
        <p class="mx-auto mt-4 max-w-2xl text-center text-base text-gray-600">{t('eguides.modules.desc')}</p>
        
        <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          
          <!-- Module 1 -->
          <article class="group flex flex-col rounded-2xl border border-[#E6F6F6] bg-gradient-to-b from-[#F5FCFC] to-white p-6 shadow-sm transition-all hover:border-[#4ED2CE]/40 hover:shadow-md">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#4ED2CE]/15 text-[#1CABB0] transition-colors group-hover:bg-[#1CABB0]/25">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plane "><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"></path></svg>
            </div>
            <p class="text-[11px] font-bold uppercase tracking-wider text-[#4ED2CE]">Module 1</p>
            <h3 class="mt-2 text-lg font-bold text-gray-900">{t('eguides.mod1.title')}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-gray-600">{t('eguides.mod1.desc')}</p>
          </article>

          <!-- Module 2 -->
          <article class="group flex flex-col rounded-2xl border border-[#E6F6F6] bg-gradient-to-b from-[#F5FCFC] to-white p-6 shadow-sm transition-all hover:border-[#4ED2CE]/40 hover:shadow-md">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#4ED2CE]/15 text-[#1CABB0] transition-colors group-hover:bg-[#4ED2CE]/25">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-globe "><circle cx="12" cy="12" r="10"></circle><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path><path d="M2 12h20"></path></svg>
            </div>
            <p class="text-[11px] font-bold uppercase tracking-wider text-[#4ED2CE]">Module 2</p>
            <h3 class="mt-2 text-lg font-bold text-gray-900">{t('eguides.mod2.title')}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-gray-600">{t('eguides.mod2.desc')}</p>
          </article>

          <!-- Module 3 -->
          <article class="group flex flex-col rounded-2xl border border-[#E6F6F6] bg-gradient-to-b from-[#F5FCFC] to-white p-6 shadow-sm transition-all hover:border-[#4ED2CE]/40 hover:shadow-md">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#4ED2CE]/15 text-[#1CABB0] transition-colors group-hover:bg-[#4ED2CE]/25">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-briefcase "><rect width="20" height="14" x="2" y="7" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
            </div>
            <p class="text-[11px] font-bold uppercase tracking-wider text-[#4ED2CE]">Module 3</p>
            <h3 class="mt-2 text-lg font-bold text-gray-900">{t('eguides.mod3.title')}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-gray-600">{t('eguides.mod3.desc')}</p>
          </article>

          <!-- Module 4 -->
          <article class="group flex flex-col rounded-2xl border border-[#E6F6F6] bg-gradient-to-b from-[#F5FCFC] to-white p-6 shadow-sm transition-all hover:border-[#4ED2CE]/40 hover:shadow-md">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#4ED2CE]/15 text-[#1CABB0] transition-colors group-hover:bg-[#4ED2CE]/25">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-home "><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
            </div>
            <p class="text-[11px] font-bold uppercase tracking-wider text-[#4ED2CE]">Module 4</p>
            <h3 class="mt-2 text-lg font-bold text-gray-900">{t('eguides.mod4.title')}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-gray-600">{t('eguides.mod4.desc')}</p>
          </article>

          <!-- Module 5 -->
          <article class="group flex flex-col rounded-2xl border border-[#E6F6F6] bg-gradient-to-b from-[#F5FCFC] to-white p-6 shadow-sm transition-all hover:border-[#4ED2CE]/40 hover:shadow-md">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#4ED2CE]/15 text-[#1CABB0] transition-colors group-hover:bg-[#4ED2CE]/25">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-laptop "><path d="M20 16V7a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v9m16 0H4m16 0 1.28 2.55a1 1 0 0 1-.9 1.45H3.62a1 1 0 0 1-.9-1.45L4 16"></path></svg>
            </div>
            <p class="text-[11px] font-bold uppercase tracking-wider text-[#4ED2CE]">Module 5</p>
            <h3 class="mt-2 text-lg font-bold text-gray-900">{t('eguides.mod5.title')}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-gray-600">{t('eguides.mod5.desc')}</p>
          </article>

          <!-- Module 6 -->
          <article class="group flex flex-col rounded-2xl border border-[#E6F6F6] bg-gradient-to-b from-[#F5FCFC] to-white p-6 shadow-sm transition-all hover:border-[#4ED2CE]/40 hover:shadow-md">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#4ED2CE]/15 text-[#1CABB0] transition-colors group-hover:bg-[#4ED2CE]/25">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-wallet "><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"></path><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"></path><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"></path></svg>
            </div>
            <p class="text-[11px] font-bold uppercase tracking-wider text-[#4ED2CE]">Module 6</p>
            <h3 class="mt-2 text-lg font-bold text-gray-900">{t('eguides.mod6.title')}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-gray-600">{t('eguides.mod6.desc')}</p>
          </article>

          <!-- Module 7 -->
          <article class="group flex flex-col rounded-2xl border border-[#E6F6F6] bg-gradient-to-b from-[#F5FCFC] to-white p-6 shadow-sm transition-all hover:border-[#4ED2CE]/40 hover:shadow-md">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#4ED2CE]/15 text-[#1CABB0] transition-colors group-hover:bg-[#4ED2CE]/25">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin "><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </div>
            <p class="text-[11px] font-bold uppercase tracking-wider text-[#4ED2CE]">Module 7</p>
            <h3 class="mt-2 text-lg font-bold text-gray-900">{t('eguides.mod7.title')}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-gray-600">{t('eguides.mod7.desc')}</p>t+Y)
          </article>

          <!-- Module 8 -->
          <article class="group flex flex-col rounded-2xl border border-[#E6F6F6] bg-gradient-to-b from-[#F5FCFC] to-white p-6 shadow-sm transition-all hover:border-[#4ED2CE]/40 hover:shadow-md">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#4ED2CE]/15 text-[#1CABB0] transition-colors group-hover:bg-[#4ED2CE]/25">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-book-open "><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
            </div>
            <p class="text-[11px] font-bold uppercase tracking-wider text-[#4ED2CE]">Module 8</p>
            <h3 class="mt-2 text-lg font-bold text-gray-900">{t('eguides.mod8.title')}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-gray-600">{t('eguides.mod8.desc')}</p>
          </article>

        </div>
      </div>
    </section>

  

    <!-- Bottom CTA Section -->
    <section class="border-t border-white/10 bg-gradient-to-br from-[#1CABB0] via-[#1ba9ae] to-[#15939a] py-20 text-center text-white">
      <div class="mx-auto max-w-2xl px-6">
        <span class="inline-block rounded-full bg-white/15 px-4 py-1 text-xs font-semibold uppercase tracking-wider">
          {t('travelAdvice.cta.badge')}
        </span>
        <h2 class="mt-6 font-libre text-3xl font-semibold md:text-4xl">{t('travelAdvice.cta.title')}</h2>
        <p class="mt-4 text-lg text-white/90">{t('travelAdvice.cta.desc')}</p>
        <div class="mt-10 flex flex-col items-center gap-3">
          <a href={lang === 'nl' 
  ? '/nl/route-planner?country=australia' 
  : '/en/route-planner?country=australia'}
          class="inline-flex items-center justify-center px-8 py-3 rounded-full font-medium transition-all duration-300 transform hover:scale-105 bg-white text-[#1CABB0] hover:bg-[#E6F6F6] hover:text-[#15939a] shadow-xl">
            {t('travelAdvice.cta.btn')}
          </a>
       
        </div>
      </div>
    </section>


  </div>

  
</BaseLayout>

