---
import { ui, defaultLang } from '../../i18n/ui';

export interface Props {
  lang?: keyof typeof ui;
}

const { lang = defaultLang } = Astro.props;
---

<section class="relative overflow-hidden py-24">

  <!-- Background -->
  <div class="absolute inset-0 pointer-events-none">
    <img
      src="/images/australia/australiaLow.svg"
      alt=""
class="absolute left-1/2 top-1/2 translate-x-[15%] -translate-y-[65%] w-[35%] opacity-50"
    />
    <div class="absolute inset-0 bg-[#FFFFF0]/10"></div>
  </div>

  <div class="max-w-6xl mx-auto px-6 relative z-10 grid lg:grid-cols-2 gap-16 items-start ">

    <!-- LEFT -->
    <div class="max-w-xl">

      <span class="text-[#1CABB0] font-semibold uppercase tracking-wider">
        {ui[lang]['australia.intro.label']}
      </span>

      <h2 class="text-4xl sm:text-5xl font-bold text-gray-900 mt-3 mb-6">
        {ui[lang]['australia.intro.title']}
      </h2>

      <div class="space-y-6 text-base leading-7 text-gray-700">

        <p>{ui[lang]['australia.intro.text1']}</p>
        <p>{ui[lang]['australia.intro.text2']}</p>
        <p>{ui[lang]['australia.intro.text3']}</p>

      </div>

      <!-- CTA -->
      <a
        href="/route-planner"
        class="inline-flex items-center mt-10 bg-[#1CABB0] hover:bg-[#16969A] text-white font-semibold px-7 py-4 rounded-full transition"
      >
        {ui[lang]['australia.intro.cta']}
        <span class="ml-2">→</span>
      </a>

    </div>

    <!-- RIGHT -->
<div class="flex justify-end lg:mt-45">

      <div class="bg-#FFFFF0 border border-[#FFFFF0] rounded-2xl shadow-xl p-6 max-w-sm w-full">

        <h3 class="text-xl font-bold text-gray-900 mb-6">
          {ui[lang]['australia.intro.mistakesTitle']}
        </h3>

        <ul class="space-y-3 text-gray-700 text-sm leading-snug">

          <li class="flex gap-3">
            <span class="text-[#1CABB0] font-bold">✕</span>
            <span>{ui[lang]['australia.intro.mistake1']}</span>
          </li>

          <li class="flex gap-3">
            <span class="text-[#1CABB0] font-bold">✕</span>
            <span>{ui[lang]['australia.intro.mistake2']}</span>
          </li>

          <li class="flex gap-3">
            <span class="text-[#1CABB0] font-bold">✕</span>
            <span>{ui[lang]['australia.intro.mistake3']}</span>
          </li>

          <li class="flex gap-3">
            <span class="text-[#1CABB0] font-bold">✕</span>
            <span>{ui[lang]['australia.intro.mistake4']}</span>
          </li>

          <li class="flex gap-3">
            <span class="text-[#1CABB0] font-bold">✕</span>
            <span>{ui[lang]['australia.intro.mistake5']}</span>
          </li>

          <li class="flex gap-3">
            <span class="text-[#1CABB0] font-bold">✕</span>
            <span>{ui[lang]['australia.intro.mistake6']}</span>
          </li>

        </ul>

      </div>

    </div>

  </div>

</section>