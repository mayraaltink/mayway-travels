---
import { useTranslations } from '../../i18n/ui';

const lang = (Astro.currentLocale ?? 'nl') as 'nl' | 'en';
const t = useTranslations(lang);
---

<footer class="bg-[#FBF7F1] border-t border-black/5">
  <div class="max-w-7xl mx-auto px-6 py-16">

   <div class="grid md:grid-cols-3 gap-8 items-start">

      <!-- LEFT -->
      <div>
        <span class="text-3xl font-bold font-neucha tracking-tight text-[#4ED2CE]">
  MAY WAY
</span>

     <p class="mt-4 text-sm text-gray-600 leading-relaxed max-w-[260px]">
  {t('footer.description')}
</p>
      </div>

   <!-- CENTER NAV -->
<div class="flex flex-col items-center justify-center gap-6 text-sm font-medium pt-6">

  <!-- top row -->
  <div class="flex gap-3 flex-wrap justify-center items-center">

    <a
  href="/destinations"
  class="inline-flex items-center px-5 py-2 rounded-full border border-[#39C2BE]
         bg-transparent text-[#39C2BE]
         hover:bg-[#1CABB0] hover:border-[#1CABB0] hover:text-white
         active:bg-[#1CABB0] active:border-[#1CABB0] active:text-white
         transition-colors duration-200"
>
  Australië
</a>

    <a
      href="/traveladvice"
      class="inline-flex items-center px-5 py-2 rounded-full border border-[#39C2BE] text-[#39C2BE]
             hover:bg-[#1CABB0] hover:text-white active:bg-[#1CABB0] active:text-white
             transition"
    >
      Reisadvies
    </a>

    <a
      href="/community"
      class="inline-flex items-center px-5 py-2 rounded-full border border-[#39C2BE] text-[#39C2BE]
             hover:bg-[#1CABB0] hover:text-white active:bg-[#1CABB0] active:text-white
             transition"
    >
      Community
    </a>

  </div>

  <!-- bottom row -->
  <div class="flex gap-3 flex-wrap justify-center items-center">

    <a
      href="/about"
      class="inline-flex items-center px-5 py-2 rounded-full border border-[#39C2BE] text-[#39C2BE]
             hover:bg-[#1CABB0] hover:text-white active:bg-[#1CABB0] active:text-white
             transition"
    >
      Over mij
    </a>

    <a
      href="/about#CollaborationSection"
      class="inline-flex items-center px-5 py-2 rounded-full border border-[#39C2BE] text-[#39C2BE]
             hover:bg-[#1CABB0] hover:text-white active:bg-[#1CABB0] active:text-white
             transition"
    >
      Samenwerken
    </a>

    <a
      href="/contact"
      class="inline-flex items-center px-5 py-2 rounded-full border border-[#39C2BE] text-[#39C2BE]
             hover:bg-[#1CABB0] hover:text-white active:bg-[#1CABB0] active:text-white
             transition"
    >
      Contact
    </a>

  </div>

</div>

<!-- RIGHT -->
<div class="pt-6 md:text-right flex flex-col items-end md:items-end">

  <h4 class="text-lg font-semibold text-gray-800 text-right">
    {t('footer.followTitle')}
  </h4>

  <p class="mt-3 text-sm text-gray-600 max-w-[220px] leading-relaxed break-words text-right">
    {t('footer.followText')}
  </p>

 <div class="mt-4 flex flex-row gap-3 justify-end items-center">

  <!-- Instagram -->
  <a
    href="https://instagram.com/maywaytravels"
    target="_blank"
    aria-label="Instagram @maywaytravels"
    class="text-[#39C2BE] hover:text-[#1CABB0] transition-colors duration-200"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
      fill="none" stroke="currentColor" stroke-width="2.2"
      stroke-linecap="round" stroke-linejoin="round"
      class="w-6 h-6">
      
      <rect x="3" y="3" width="18" height="18" rx="5" ry="5"/>
      <circle cx="12" cy="12" r="4.5"/>
      <circle cx="17.5" cy="6.5" r="0.8" fill="currentColor"/>
    </svg>
  </a>

  <!-- TikTok -->
  <a
    href="https://tiktok.com/@mayraxaltink"
    target="_blank"
    aria-label="TikTok @mayraxaltink"
    class="text-[#39C2BE] hover:text-[#1CABB0] transition-colors duration-200"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
      fill="none" stroke="currentColor" stroke-width="2.2"
      stroke-linecap="round" stroke-linejoin="round"
      class="w-6 h-6">

      <path d="M16 3v10.5a4.5 4.5 0 1 1-4.5-4.5"/>
      <path d="M16 3c.5 2.5 2.5 4.5 5 5"/>
    </svg>
  </a>

</div>

</div>

