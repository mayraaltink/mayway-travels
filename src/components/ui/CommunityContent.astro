---
import BaseLayout from "../../layouts/BaseLayout.astro";
import headerImg from "../../assets/Header.avif";
import { ui, defaultLang } from '../../i18n/ui';
import BlogGrid from "./BlogGrid.astro";

import MayWayMoments from "./MayWayMoments.astro";

const pathLang = Astro.url.pathname.split('/')[1];

const lang =
  pathLang === 'nl' || pathLang === 'en'
    ? pathLang
    : defaultLang;

function t(key: keyof typeof ui[typeof defaultLang]) {
  const dict = ui[lang as keyof typeof ui] ?? ui[defaultLang];
  return dict[key];
}
---

<BaseLayout>
  <section class="relative bg-[#FFFDFA]">

    <!-- HERO -->
    <div class="relative h-screen flex items-center justify-center overflow-hidden -mt-16 rounded-b-[80px]">

      <!-- GRADIENT -->
      <div class="absolute inset-0 bg-gradient-to-b from-gray-900/60 via-gray-900/30 to-transparent z-10"></div>

      <!-- IMAGE -->
<img
  src="/images/australia/aus_main.jpg"
  alt="Australia"
  class="absolute inset-0 z-0 h-full w-full object-cover"
/>


      <!-- CONTENT -->
      <div class="relative z-20 text-center text-white max-w-3xl px-6">

        <!-- PREHEADER -->
        <p class="uppercase tracking-[0.2em] text-xs md:text-xs text-white/80 mb-4">
          {t('community.preheader')}
        </p>

        <!-- TITLE -->
        <h1 class="flex flex-col leading-[0.85] tracking-[-0.03em]">

          <span class="text-xl md:text-5xl font-medium text-white">
            {t('community.titlePart1')}
          </span>

          <span class="text-3xl md:text-5xl font-semibold text-white">
            {t('community.titleHighlight')}
          </span>

        </h1>

        <!-- CTA'S -->
        <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:justify-center sm:items-center">

          <!-- PRIMARY -->
          <a
            href="#blogs"
            class="inline-flex items-center gap-2 rounded-full bg-[#1CABB0] px-8 py-3 text-sm font-semibold text-white shadow-lg transition-all duration-300 hover:scale-105 hover:bg-[#15939a]"
          >
            {t('community.ctaBlogs')}

            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
              viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </a>

          <!-- SECONDARY -->
          <a
            href="#webinars"
            class="inline-flex items-center gap-2 rounded-full border-2 border-white/60 px-8 py-3 text-sm font-semibold text-white transition-all duration-300 hover:bg-white/10 hover:border-white"
          >
            {t('community.ctaEvents')}

            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
              viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </a>

        </div>

      </div>
    </div>
  </section>

  <BlogGrid />
  <MayWayMoments />


</BaseLayout>