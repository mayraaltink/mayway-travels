---
// src/components/ui/Hero.astro
import { Image } from 'astro:assets';
import backgroundImage from '../../assets/Header.avif';
// import backgroundImage from '../../assets/pexels-1320686.jpeg';



interface Props {
  heroImage: ImageMetadata; 
  titleLine1: string;
  titleLine2: string;
  subtitle: string;
  primaryButtonText: string;
  secondaryButtonText: string;
  primaryButtonLink: string;
  secondaryButtonLink: string;
}

const { 
  heroImage,
  titleLine1, 
  titleLine2, 
  subtitle, 
  primaryButtonText, 
  secondaryButtonText,
  primaryButtonLink,
  secondaryButtonLink 
} = Astro.props;
---

<section class="relative min-h-[110vh] flex items-center justify-center overflow-hidden -mt-16 rounded-b-[80px]">
  <!-- Video Overlay Gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-gray-900/40 via-gray-900/20 to-transparent z-10"></div>
  
  <!-- Background Video -->
  <!-- <video class="absolute inset-0 z-0 h-full w-full object-cover motion-reduce:hidden" autoplay loop muted playsinline poster="/images/pexels-1320686.jpeg">
    <source src="https://cdn.coverr.co/videos/surfer-catching-a-wave-z9d2tcquzp/1080p.mp4" type="video/mp4">
  </video> -->

  <!-- Background Image (replaces video above) -->
  <Image 
    src={backgroundImage} 
    alt="Breathtaking aerial view of a tropical coastline" 
    class="absolute inset-0 z-0 h-full w-full object-cover"
    loading="eager"
    quality="mid"
  />

  <!-- LOCATION (bottom left badge) -->
<div class="absolute bottom-10 left-10 flex items-center gap-2 rounded-full bg-transparant px-4 py-2 text-sm text-white backdrop-blur-sm z-20 ">

  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white/90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
    <circle cx="12" cy="10" r="3"></circle>
  </svg>

  <span class="uppercase text-xs tracking-wide text-white/90">
    Australië · Sydney
  </span>

</div>

  <!-- Content -->
  <div class="relative z-20 text-center px-6 max-w-4xl mx-auto">
  <h1 class="flex flex-col text-center leading-[0.80] tracking-[-0.03em]">
  
  <!-- Line 1 -->
  <span class="text-xl md:text-4xl font-medium text-white">
    Jouw avontuur
  </span>

  <!-- Line 2 -->
 <span class="text-3xl md:text-5xl font-semibold text-white">
  YOUR WAY
</span>

</h1>

<!-- Subtitle directly under -->
<p class="mt-2 text-lg md:text-base text-white font-bold tracking-wide">
  Persoonlijke reisroutes & hidden gems
</p>
    
  