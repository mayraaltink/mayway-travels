---

<section class="bg-white py-24">
  <div class="max-w-6xl mx-auto px-6">

    <!-- HEADER -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h2 class="text-4xl font-bold mb-4">
        Ontdek verschillende reisroutes
      </h2>
      <p class="text-neutral-700 leading-7">
        Ontdek de mooiste routes door Australië – elk met een compleet andere vibe.
      </p>
    </div>

    <!-- GRID -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">

      {routes.map((route, i) => (
        <article
          class="group relative bg-white rounded-3xl shadow-lg overflow-hidden flex flex-col"
          data-route={i}
        >

          <!-- IMAGE WRAPPER -->
          <div class="relative h-[340px]">

            <!-- IMAGE SLIDES -->
            {route.images.map((img, idx) => (
              <img
                src={img.src}
                data-slide={i}
                data-index={idx}
                class={`absolute inset-0 w-full h-full object-cover transition-opacity duration-500 ${
                  idx === 0 ? 'opacity-100' : 'opacity-0'
                }`}
              />
            ))}

            <!-- DARK GRADIENT -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>

            <!-- TITLE IN IMAGE -->
            <div class="absolute bottom-5 left-5 text-white">
              <p class="text-[11px] uppercase tracking-[0.2em] opacity-80 mb-1">
                {route.description}
              </p>
              <h3 class="text-2xl font-bold">
                {route.title}
              </h3>
            </div>

            <!-- ARROWS -->
            <button
              class="absolute left-3 top-1/2 -translate-y-1/2 text-white text-3xl opacity-0 group-hover:opacity-100 transition"
              data-prev={i}
            >
              ‹
            </button>

            <button
              class="absolute right-3 top-1/2 -translate-y-1/2 text-white text-3xl opacity-0 group-hover:opacity-100 transition"
              data-next={i}
            >
              ›
            </button>

          </div>

          <!-- CONTENT -->
          <div class="p-6 flex flex-col gap-4">

            <p class="text-sm text-neutral-700 leading-relaxed">
              {route.details}
            </p>

            <button
              class="text-sm font-medium text-[#2AA6A1] hover:underline text-left"
              data-toggle={i}
            >
              Lees meer
            </button>

          </div>

          <!-- EXPAND -->
          <div
            class="absolute inset-0 bg-white p-6 translate-y-full transition duration-500"
            data-expand={i}
          >

            <h4 class="text-xl font-bold mb-3">
              {route.title}
            </h4>

            <p class="text-sm text-neutral-700 leading-relaxed">
              {route.details}
            </p>

            <button
              class="mt-6 text-sm text-[#2AA6A1] underline"
              data-close={i}
            >
              Sluiten
            </button>

          </div>

        </article>
      ))}

    </div>
  </div>
</section>

