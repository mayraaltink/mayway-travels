---
import { ui, defaultLang } from '../../i18n/ui';

const lang = Astro.currentLocale || defaultLang;

function t(key: keyof typeof ui[typeof defaultLang]) {
  return ui[lang as keyof typeof ui][key];
}

const steps = [
  { key: 'step1' },
  { key: 'step2' },
  { key: 'step3' },
  { key: 'step4' },
  { key: 'step5' }
];
---

<section class="py-20 bg-[#FFFDFA]">
  <div class="mx-auto max-w-6xl px-6">

    <!-- TURQUOISE CONTAINER -->
    <div class="rounded-[2.5rem] bg-[#E6F6F6] px-6 py-14 md:px-10 md:py-16 relative">

      <!-- HEADER -->
      <div class="text-center mb-12">
        <h2 class="font-libre text-3xl md:text-4xl font-bold text-gray-900">
          {t('eguides.steps.title')}
        </h2>
        <p class="mt-3 text-gray-600 text-lg">
          {t('eguides.steps.desc')}
        </p>
      </div>

      <!-- WRAPPER -->
      <div class="relative">

        <!-- LEFT BUTTON -->
        <button
          type="button"
          data-step-prev
          class="absolute left-0 top-1/2 -translate-y-1/2 z-10 p-2 rounded-full bg-white shadow hover:bg-[#F5FCFC] text-[#4ED2CE]"
        >
          <svg width="26" height="26" fill="none" stroke="currentColor" stroke-width="2">
            <path d="m15 18-6-6 6-6"/>
          </svg>
        </button>

        <!-- RIGHT BUTTON -->
        <button
          type="button"
          data-step-next
          class="absolute right-0 top-1/2 -translate-y-1/2 z-10 p-2 rounded-full bg-white shadow hover:bg-[#F5FCFC] text-[#4ED2CE]"
        >
          <svg width="26" height="26" fill="none" stroke="currentColor" stroke-width="2">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </button>

        <!-- TRACK -->
        <div
          data-step-track
          class="flex gap-5 overflow-x-auto scroll-smooth no-scrollbar px-10"
        >

          {steps.map((step, index) => (

            <details
              class="group shrink-0 w-[260px] rounded-2xl border border-white/60 bg-white shadow-sm transition hover:bg-[#F5FCFC] hover:border-[#4ED2CE]/40"
            >

              <!-- HEADER -->
              <summary class="cursor-pointer list-none px-5 py-5">

                <!-- STEP LABEL -->
                <p class="text-[11px] font-bold uppercase tracking-wider text-[#4ED2CE] mb-2">
                  STEP {index + 1}
                </p>

                <div class="flex items-center justify-between">

                  <div class="flex items-center gap-3">

                    <!-- NUMBER -->
                    <span class="h-10 w-10 flex items-center justify-center rounded-xl bg-[#E6F6F6] text-[#1CABB0] font-bold">
                      {index + 1}
                    </span>

                    <!-- TITLE -->
                    <h3 class="font-semibold text-gray-900 text-sm">
                      {t(`eguides.steps.${step.key}.title` as any)}
                    </h3>

                  </div>

                  <!-- ARROW -->
                  <span class="text-[#4ED2CE] group-open:rotate-180 transition-transform">
                    ⌄
                  </span>

                </div>

              </summary>

              <!-- CONTENT -->
              <div class="px-5 pb-5 text-sm text-gray-600 leading-relaxed">
                {t(`eguides.steps.${step.key}.text` as any)}
              </div>

            </details>

          ))}

        </div>
      </div>
    </div>
  </div>
</section>

<!-- HIDE SCROLLBAR -->
<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<!-- NAVIGATION SCRIPT -->
<script>
  function initSteps() {
    const track = document.querySelector('[data-step-track]');
    const prev = document.querySelector('[data-step-prev]');
    const next = document.querySelector('[data-step-next]');

    if (!track || !prev || !next) return;

    const scrollAmount = 280;

    prev.addEventListener('click', () => {
      track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    });

    next.addEventListener('click', () => {
      track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    });
  }

  document.addEventListener('astro:page-load', initSteps);
</script>