---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ui, defaultLang } from '../../i18n/ui';
import CollaborationSection from "./CollaborationSection.astro";
import PartnerSection from '../ui/PartnerSection.astro';

// Detect language from URL
const lang = Astro.currentLocale || defaultLang;

// Translation helper
function t(key: keyof typeof ui[typeof defaultLang]) {
  return ui[lang as keyof typeof ui][key];
}
---

<BaseLayout title={t('about.title')}>

<section class="w-screen px-6 py-10">

  <!-- OUTER HERO -->
  <div class="relative w-full min-h-[90vh] overflow-hidden rounded-[50px] flex flex-col md:flex-row">

    <!-- LEFT IMAGE (UNCHANGED) -->
    <div class="relative w-full md:w-1/2 min-h-[40vh] md:min-h-full">

      <img
        src="/images/back%20on%20the%20island%F0%9F%98%83.jpg"
        alt="Reizen"
        class="absolute inset-0 h-full w-full object-cover"
      />

      <!-- overlay -->
      <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-black/30"></div>

      <!-- location badge (KEEP) -->
      <div class="absolute bottom-6 left-6 flex items-center gap-2 rounded-full bg-black/35 px-4 py-2 text-sm text-white backdrop-blur-sm">
        <span class="uppercase text-xs tracking-wide">
          {t('about.location')}
        </span>
      </div>

    </div>

    <!-- RIGHT SIDE (UPDATED ONLY HERE) -->
    <div class="w-full md:w-1/2 flex items-center justify-center bg-gradient-to-br from-[#1CABB0] via-[#1ba9ae] to-[#15939a] px-8 py-16 md:px-14">

      <div class="max-w-xl text-white">

        <!-- FIXED INTRO -->
        <h1 class="font-libre text-3xl sm:text-4xl md:text-5xl italic mb-4">
          Hi, ik ben Mayra
        </h1>

      <div class="mb-8 text-white/90 leading-relaxed space-y-4">

  <p>{t('about.intro.p1')}</p>
  <p>{t('about.intro.p2')}</p>
  <p>{t('about.intro.p3')}</p>

</div>

       <div class="flex flex-wrap gap-2 mb-6">

  <button onclick="setTab('travel')" id="tab-travel"
    class="tab-btn active-tab">
    Mijn verhaal
  </button>

  <button onclick="setTab('work')" id="tab-work"
    class="tab-btn">
    Werk
  </button>

  <button onclick="setTab('vision')" id="tab-vision"
    class="tab-btn">
    Visie
  </button>

</div>

        <!-- DYNAMIC TEXT -->
        <div id="tabContent"
          class="text-white/90 leading-relaxed transition-opacity duration-300">
        </div>

      </div>

    </div>

  </div>

</section>

<!-- SCRIPT -->
<script is:inline>

  const content = {
    travel: `
Wat begon met nieuwsgierigheid is uitgegroeid tot een levensstijl vol avontuur, vrijheid en nieuwe ervaringen. Van reizen door Tanzania en Peru tot backpacken door Azië en het opbouwen van een leven in Australië: elke stap heeft bijgedragen aan het verhaal achter MAY WAY.
    `,

    work: `
Als reisspecialist werkte ik samen met lokale tour operators, hostels en travel providers. Hierdoor kon ik reizigers helpen hun ideale reis samen te stellen en zelf de beste ervaringen testen.
    `,

    vision: `
Met MAY WAY wil ik je inspireren om te durven gaan, te ontdekken en je eigen verhaal te schrijven — op jouw manier.
    `
  };

 let activeTab = null;

function setTab(tab) {

  const el = document.getElementById("tabContent");

  // ALS je op dezelfde tab klikt → sluiten
  if (activeTab === tab) {
    activeTab = null;
    el.style.opacity = 0;

    setTimeout(() => {
      el.innerHTML = "";
      el.style.opacity = 1;
    }, 150);

    document.querySelectorAll(".tab-btn").forEach(btn => {
      btn.classList.remove("active-tab");
    });

    return;
  }

  // open nieuwe tab
  activeTab = tab;

  el.style.opacity = 0;

  setTimeout(() => {
    el.innerHTML = content[tab];
    el.style.opacity = 1;
  }, 150);

  document.querySelectorAll(".tab-btn").forEach(btn => {
    btn.classList.remove("active-tab");
  });

  document.getElementById(`tab-${tab}`).classList.add("active-tab");
}

</script>

<style>
  .tab-btn {
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(255,255,255,0.10);
    color: white;
    font-size: 14px;
    transition: all 0.2s ease;
    backdrop-filter: blur(10px);
    cursor: pointer;
    border: 1px solid rgba(255,255,255,0.15);
  }

  .tab-btn:hover {
    background: rgba(255,255,255,0.18);
    transform: translateY(-1px);
    border-color: rgba(255,255,255,0.25);
  }

  .active-tab {
    background: white;
    color: #15939a;
    font-weight: 600;
    border-color: white;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
  }
</style>
<CollaborationSection />

<PartnerSection />
  

</BaseLayout>