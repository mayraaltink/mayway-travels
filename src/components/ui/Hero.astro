---
// src/components/ui/Hero.astro
import { Image } from 'astro:assets';
import backgroundImage from '../../assets/moalboal_drone_2.webp';
// import backgroundImage from '../../assets/pexels-1320686.jpeg';



interface Props {
  heroImage: ImageMetadata; 
  titleLine1: string;
  titleLine2: string;
  subtitle: string;
  primaryButtonText: string;
  secondaryButtonText: string;
  primaryButtonLink: string;
  secondaryButtonLink: string;
}

const { 
  heroImage,
  titleLine1, 
  titleLine2, 
  subtitle, 
  primaryButtonText, 
  secondaryButtonText,
  primaryButtonLink,
  secondaryButtonLink 
} = Astro.props;
---

<section class="relative h-screen flex items-center justify-center overflow-hidden -mt-16">
  <!-- Video Overlay Gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-gray-900/40 via-gray-900/20 to-transparent z-10"></div>
  
  <!-- Background Video -->
  <!-- <video class="absolute inset-0 z-0 h-full w-full object-cover motion-reduce:hidden" autoplay loop muted playsinline poster="/images/pexels-1320686.jpeg">
    <source src="https://cdn.coverr.co/videos/surfer-catching-a-wave-z9d2tcquzp/1080p.mp4" type="video/mp4">
  </video> -->

  <!-- Background Image (replaces video above) -->
  <Image 
    src={backgroundImage} 
    alt="Breathtaking aerial view of a tropical coastline" 
    class="absolute inset-0 z-0 h-full w-full object-cover"
    loading="eager"
    quality="mid"
  />

  <!-- Content -->
  <div class="relative z-20 text-center px-6 max-w-4xl mx-auto">
  <h1 class="flex flex-col text-center leading-[0.80] tracking-[-0.03em]">
  
  <!-- Line 1 -->
  <span class="text-xl md:text-4xl font-medium text-white">
    Jouw avontuur
  </span>

  <!-- Line 2 -->
 <span class="text-3xl md:text-5xl font-semibold text-[#4ED2CE]">
  YOUR WAY
</span>

</h1>

<!-- Subtitle directly under -->
<p class="mt-2 text-base md:text-lg text-white/80 font-medium tracking-wide">
  De community voor reizigers die meer uit het leven willen halen.
</p>
    
  