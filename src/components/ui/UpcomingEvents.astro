---
---

<section class="bg-[#1CABB0] text-white py-16">

  <div class="max-w-7xl mx-auto px-6">

    <!-- HEADER -->
    <div class="max-w-3xl mx-auto text-center mb-10">

      <h2 class="text-3xl md:text-4xl font-semibold mb-3">
        Upcoming Events
      </h2>

      <p class="text-white/90 text-sm md:text-base leading-relaxed">
        Webinars and live sessions coming soon to help you prepare for your journey.
      </p>

    </div>

    <!-- COMPACT EVENT CARD -->
    <div class="max-w-2xl mx-auto">

      <div class="bg-white text-gray-900 rounded-3xl shadow-lg p-6 md:p-8">

        <!-- top label -->
        <p class="text-xs tracking-[0.2em] uppercase text-[#1CABB0] mb-3">
          Webinar
        </p>

        <!-- title -->
        <h3 class="text-xl md:text-2xl font-semibold mb-3">
          Everything you need before travelling Australia
        </h3>

        <!-- description -->
        <p class="text-gray-600 text-sm mb-6 leading-relaxed">
          Planning • Visas • Budget • Jobs • Q&A
        </p>

        <!-- meta -->
        <div class="space-y-2 text-sm text-gray-600">

          <div class="flex justify-between">
            <span>Location</span>
            <span class="text-gray-900 font-medium">Online</span>
          </div>

          <div class="flex justify-between">
            <span>Date</span>
            <span class="text-gray-900 font-medium">Coming soon</span>
          </div>

          <div class="flex justify-between">
            <span>Spots</span>
            <span class="text-gray-900 font-medium">Limited</span>
          </div>

        </div>

        <!-- CTA -->
        <div class="mt-6">
          <a
            href="/contact"
            class="inline-flex items-center text-[#1CABB0] font-semibold text-sm hover:gap-2 transition-all"
          >
            Be the first to know
            <span class="ml-2">→</span>
          </a>
        </div>

      </div>

    </div>

  </div>

</section>