---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ui, defaultLang } from "../../i18n/ui";

const lang = Astro.currentLocale || defaultLang;

function t(key: keyof typeof ui[typeof defaultLang]) {
  return ui[lang as keyof typeof ui][key];
}

const communityCards = [
  {
    icon: "🌍",
    titleKey: "community.connect.title",
    textKey: "community.connect.text",
  },
  {
    icon: "✈️",
    titleKey: "community.share.title",
    textKey: "community.share.text",
  },
  {
    icon: "🤝",
    titleKey: "community.meet.title",
    textKey: "community.meet.text",
  },
  {
    icon: "📸",
    titleKey: "community.inspire.title",
    textKey: "community.inspire.text",
  },
];
---

<BaseLayout title={t("community.pageTitle")}>
  <div class="min-h-[60vh] bg-[#FFFDFA]">

    <!-- Header -->
    <header class="border-b border-[#E8F5F4] bg-gradient-to-b from-white to-[#FFFDFA] px-6 pb-14 pt-28">
      <div class="mx-auto max-w-6xl">
        <p class="mb-3 text-xs font-bold uppercase tracking-[0.2em] text-[#4ED2CE]">
          {t("community.kicker")}
        </p>

        <h1 class="font-libre text-4xl font-bold text-gray-900 md:text-5xl">
          {t("community.title")}
        </h1>

        <p class="mt-5 max-w-2xl text-lg leading-relaxed text-gray-600">
          {t("community.subtitle")}
        </p>
      </div>
    </header>

    <!-- Cards -->
    <div class="mx-auto max-w-6xl px-6 py-14 md:py-20">
      <div class="grid gap-6 md:grid-cols-2">
        {
          communityCards.map((card) => (
            <div class="rounded-2xl border border-[#E6F6F6] bg-white p-8 shadow-sm transition-shadow hover:border-[#4ED2CE]/30 hover:shadow-md">
              <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-[#E6F6F6] text-[#1CABB0] text-xl">
                {card.icon}
              </div>

              <h2 class="text-xl font-bold text-gray-900">
                {t(card.titleKey as any)}
              </h2>

              <p class="mt-3 leading-relaxed text-gray-600">
                {t(card.textKey as any)}
              </p>
            </div>
          ))
        }
      </div>

      <!-- CTA -->
      <div class="mt-16 rounded-2xl border border-dashed border-[#4ED2CE]/40 bg-[#F5FCFC] p-8 md:p-10">
        <h2 class="font-libre text-2xl font-bold text-gray-900">
          {t("community.cta.title")}
        </h2>

        <p class="mt-3 max-w-2xl text-gray-600">
          {t("community.cta.text")}
        </p>

        <a
          class="mt-6 inline-flex font-semibold text-[#1CABB0] underline-offset-4 hover:text-[#4ED2CE] hover:underline"
          href={`/${lang}/contact`}
        >
          {t("community.cta.link")}
        </a>
      </div>
    </div>
  </div>
</BaseLayout>