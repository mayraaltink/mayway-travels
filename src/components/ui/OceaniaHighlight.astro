---
import { useTranslations } from '../../i18n/ui';

const lang = Astro.currentLocale || 'nl';
const t = useTranslations(lang as 'nl' | 'en');
---

<!-- Header Image Hero -->
<section class="relative w-full h-[60vh] md:h-[70vh] overflow-hidden px-6 pt-24">

  <!-- IMAGE WRAPPER (rounded) -->
  <div class="absolute inset-6 overflow-hidden rounded-[40px]">

    <img
      src="/images/australia/aus_main.jpg"
      alt="Australia"
      class="h-full w-full object-cover scale-105"
    />

    <!-- GRADIENT OVERLAY -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-black/10"></div>

  </div>

  <!-- CONTENT -->
  <div class="relative z-10 flex h-full items-center justify-center text-center">

    <div class="max-w-3xl text-white">

      <h2 class="flex flex-col leading-[0.9] tracking-[-0.03em] mb-5 text-white">

        <span class="text-xl md:text-4xl font-medium text-white">
          Ontdek de diversiteit
        </span>

        <span class="text-3xl md:text-4xl font-semibold text-white">
          van Oceanië
        </span>

      </h2>

      <p class="text-base md:text-base leading-[1.8] text-white/90 mb-6">
        {t('oceania.description')}
      </p>

     <a
  href={`/${lang}/destinations/australia`}
  class="inline-flex items-center gap-2 text-base font-semibold text-white bg-white/10 backdrop-blur-md px-5 py-3 rounded-full border border-white/30 hover:bg-white/20 transition"
>
  {t('oceania.card.button')}

  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="transition group-hover:translate-x-1"
  >
    <path d="M5 12h14"></path>
    <path d="m12 5 7 7-7 7"></path>
  </svg>
</a>