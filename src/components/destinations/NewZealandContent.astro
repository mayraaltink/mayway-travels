---
import DestinationContent from "./DestinationContent.astro";
import { ui, defaultLang } from '../../i18n/ui';

// Get current language
const currentPath = Astro.url.pathname;
const lang = (Astro.currentLocale || (currentPath.startsWith('/en') ? 'en' : defaultLang)) as keyof typeof ui;

// Translation helper
function t(key: keyof typeof ui[typeof lang]) {
  return ui[lang][key];
}
---

<DestinationContent
  title={t('nz.page.title')}
  description={t('nz.page.desc')}
  capital={t('nz.page.capital')}
  language={t('nz.page.language')}
  currency={t('nz.page.currency')}
  imageSrc="/images/new-zealand/nz_main.jpg"
  imageAlt="Beautiful landscape in New Zealand"
  planUrl={lang === 'nl' ? '/nl/route-planner?country=new-zealand' : '/en/route-planner?country=new-zealand'}
  guideUrl={lang === 'nl' ? '/eguides/' : '/en/eguides/'}
>
</DestinationContent>