---
<section class="bg-[#F3FBFB] py-24">
  <div class="max-w-6xl mx-auto px-6">

    <!-- TITLE -->
<h2 class="text-4xl font-bold mb-4">
  {t["routes.section.title"]}
</h2>

<p class="text-neutral-700 leading-7">
  {t["routes.section.subtitle"]}
</p>
    <!-- GRID -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

      {routes.map((route) => (
    <div class="route-card bg-white rounded-3xl shadow-xl overflow-hidden">

          <!-- SWIPE -->
          <div class="relative overflow-hidden">

            <div class="track flex transition-transform duration-300 ease-out">
              {route.images.map((img) => (
                <div class="min-w-full relative">
                  <img
                    src={img.src}
                    class="w-full h-[280px] object-cover"
                  />

                  <div class="absolute bottom-3 left-3 bg-black/60 text-white text-xs px-2 py-1 rounded-full">
                    {img.location}
                  </div>
                </div>
              ))}
            </div>

            <!-- ARROWS -->
            <button class="prev absolute left-2 top-1/2 -translate-y-1/2 bg-white/80 w-8 h-8 rounded-full">
              ‹
            </button>

            <button class="next absolute right-2 top-1/2 -translate-y-1/2 bg-white/80 w-8 h-8 rounded-full">
              ›
            </button>

          </div>

          <!-- CONTENT -->
          <div class="p-5">

            <h3 class="text-lg font-bold mb-1">
              {route.title}
            </h3>

            <p class="text-neutral-600 text-sm leading-relaxed">
              {route.tagline}
            </p>

           <div class="expand text-sm text-neutral-700 max-h-0 overflow-hidden transition-all duration-500 mt-3 space-y-3">


 {typeof route.expand !== "string" && (
  <ul class="list-disc pl-5 space-y-1">
    {route.expand.highlights.map((item) => (
      <li>{item}</li>
    ))}
  </ul>
)}

</div>
            <button class="toggle mt-3 text-[#2AA6A1] text-sm font-medium">
              Lees meer
            </button>

          </div>

        </div>
      ))}

    </div>
  </div>
</section>
<script is:inline>
document.querySelectorAll(".route-card").forEach((card) => {

  const track = card.querySelector(".track");
  const next = card.querySelector(".next");
  const prev = card.querySelector(".prev");
  const toggle = card.querySelector(".toggle");
  const expand = card.querySelector(".expand");

  const locationLabel = card.querySelector(".current-location");

  let index = 0;
  const slides = track.children.length;

  const update = () => {
    track.style.transform = `translateX(-${index * 100}%)`;

    const activeSlide = track.children[index];
    const location = activeSlide.querySelector(".location-tag")?.textContent;

    if (locationLabel) {
      locationLabel.textContent = location || "";
    }
  };

  // init
  update();

  // 👉 CLICK OP FOTO = NEXT SLIDE
  track.addEventListener("click", () => {
    index = (index + 1) % slides;
    update();
  });

  next?.addEventListener("click", (e) => {
    e.stopPropagation();
    index = (index + 1) % slides;
    update();
  });

  prev?.addEventListener("click", (e) => {
    e.stopPropagation();
    index = (index - 1 + slides) % slides;
    update();
  });

  let open = false;

  toggle?.addEventListener("click", () => {
    open = !open;

    if (open) {
      expand.style.maxHeight = expand.scrollHeight + "px";
      toggle.textContent = "Minder lezen";
    } else {
      expand.style.maxHeight = "0px";
      toggle.textContent = "Lees meer";
    }
  });

});
</script>