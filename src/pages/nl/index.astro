---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/ui/Hero.astro';
import backgroundImage from '../../assets/moalboal_drone_2.webp';
import HomeCarousel from '../../components/ui/HomeCarousel.astro';
// import backgroundImage from '../../assets/pexels-1320686.jpeg';
import { ui } from '../../i18n/ui';
const t = ui.nl;
import AboutMeHome from '../../components/ui/AboutMeHome.astro';
---



<BaseLayout title="Home | MAYWAY travels">
  
  <!-- Pass the Dutch text as props to the reusable Hero component -->
  <Hero 
    heroImage={backgroundImage}
    titleLine1="jouw avontuur,"
    titleLine2="YOUR WAY"
    subtitle="Personal travel experiences & custom routes"
    primaryButtonText="Plan jouw reis"
    primaryButtonLink="/nl/contact"
    secondaryButtonText="Bekijk e-gidsen"
    secondaryButtonLink="/nl/e-gidsen"
  />
<AboutMeHome />

  <HomeCarousel />
  <!-- The next sections (Hotspots, About Mayra, etc.) will go here! -->



</BaseLayout>