
---
import { useTranslations } from '../../i18n/ui';

const lang = (Astro.currentLocale ?? 'nl') as 'nl' | 'en';
const t = useTranslations(lang);
const get = (k: string) => t(k as any);

const hotspots = [
  'mamanuca',
  'yasawa',
  'nadi',
  'coral_coast',
  'taveuni',
  'suva',
];
---

<section class="py-24 px-6 bg-[#F3FBFA]" data-carousel-wrapper>
  <div class="max-w-6xl mx-auto">

<!-- HEADER -->
<div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-8 mb-14 ml-4">

  <!-- LEFT -->
  <h2 class="max-w-xl leading-[0.95]">

    <span class="block text-3xl md:text-4xl font-bold   text-gray-800 ">
      {t('hotspots_title_line1')}
    </span>

 

  </h2>

  <!-- RIGHT -->
  <p class="lg:max-w-md lg:text-left text-base text-gray-600 leading-relaxed lg:pt-2">
    {t('hotspots_desc')}
  </p>

</div>
    <!-- TRACK -->
    <div
      data-carousel-track
      class="flex gap-6 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-2 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
    >
      {hotspots.map((key) => (
        <article class="relative flex-shrink-0 w-[280px] snap-start rounded-3xl overflow-hidden shadow-lg h-[420px]">

          <img
            src={`/images/${key}.jpg`}
            class="absolute inset-0 w-full h-full object-cover"
          />

          <div class="absolute inset-0 bg-black/40"></div>

      <div class="absolute inset-0 flex flex-col justify-end p-5 text-white text-center items-center">

            <!-- BADGE -->
            <p class="text-[11px] uppercase tracking-[0.2em] opacity-90 mb-2">
       {get(`${key}_badge`)}
            </p>

            <!-- TITLE -->
            <h3 class="text-2xl font-bold mb-2">
              {get(`${key}_title`)}
            </h3>

            <!-- TEXT -->
            <p class="text-sm opacity-80 line-clamp-2 mb-4">
              {get(`${key}_text`)}
            </p>

            <!-- BUTTON -->
            <button class="inline-flex items-center gap-2 rounded-full border-2 border-white px-5 py-2.5 text-sm hover:bg-white/15">
              {t('hotspot_btn')}
            </button>

  
    </div>
        </article>
      ))}
    </div>

    <!-- CONTROLS -->
<div class="flex items-center justify-center gap-6 mt-8">

  <!-- LEFT -->
  <button data-carousel-prev class="text-2xl text-[#4ED2CE]">
    ‹
  </button>

  <!-- DOTS -->
  <div class="flex gap-2">
    {hotspots.map((_, i) => (
      <button
        type="button"
        data-carousel-dot
        class={`h-2.5 rounded-full transition-all ${
          i === 0 ? 'w-8 bg-[#4ED2CE]' : 'w-2.5 bg-gray-300'
        }`}
      />
    ))}
  </div>

  <!-- RIGHT -->
  <button data-carousel-next class="text-2xl text-[#4ED2CE]">
    ›
  </button>

</div>
<script>
  function initHotspotCarousel() {
    const wrapper = document.querySelector('[data-carousel-wrapper]');
    if (!wrapper) return;

   const track = wrapper.querySelector('[data-carousel-track]') as HTMLElement;
const next = wrapper.querySelector('[data-carousel-next]') as HTMLButtonElement;
const prev = wrapper.querySelector('[data-carousel-prev]') as HTMLButtonElement;
const dots = Array.from(
  wrapper.querySelectorAll('[data-carousel-dot]')
) as HTMLElement[];
    if (!track || !next || !prev || !dots.length) return;

    const gap = 24;

const getItemWidth = () =>
  ((track.firstElementChild as HTMLElement)?.offsetWidth ?? 0) + gap;

    const getMaxIndex = () => {
      const maxScroll = track.scrollWidth - track.clientWidth;
      return Math.max(0, Math.round(maxScroll / getItemWidth()));
    };

    const getIndex = () => {
      return Math.round(track.scrollLeft / getItemWidth());
    };

    const updateDots = () => {
      const index = getIndex();
      const maxIndex = getMaxIndex();

      dots.forEach((dot, i) => {
        // verberg overtollige dots
        if (i > maxIndex) {
          dot.style.display = 'none';
          return;
        }

        dot.style.display = 'block';

        if (i === index) {
          dot.classList.add('bg-[#4ED2CE]', 'w-4');
          dot.classList.remove('bg-gray-300', 'w-2.5');
        } else {
          dot.classList.remove('bg-[#4ED2CE]', 'w-4');
          dot.classList.add('bg-gray-300', 'w-2.5');
        }
      });
    };

   const scrollToIndex = (i: number) => {
  track.scrollTo({
    left: i * getItemWidth(),
    behavior: 'smooth'
  });
};

    next.addEventListener('click', () => {
      scrollToIndex(Math.min(getIndex() + 1, getMaxIndex()));
      setTimeout(updateDots, 250);
    });

    prev.addEventListener('click', () => {
      scrollToIndex(Math.max(getIndex() - 1, 0));
      setTimeout(updateDots, 250);
    });

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        scrollToIndex(i);
        setTimeout(updateDots, 250);
      });
    });

    track.addEventListener('scroll', updateDots, { passive: true });

    updateDots();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHotspotCarousel);
  } else {
    initHotspotCarousel();
  }
</script>
