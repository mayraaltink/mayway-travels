---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTAButtons from "../ui/CTAButtons.astro";
import { ui, defaultLang } from '../../i18n/ui';


export interface Props {
  title: string;
  description: string;
  capital: string;
  language: string;
  currency: string;
  imageSrc: string;
  imageAlt: string;
  planUrl: string;   
  guideUrl: string;  
}

const { 
  title, 
  description, 
  capital, 
  language, 
  currency, 
  imageSrc, 
  imageAlt,
  planUrl,
  guideUrl
} = Astro.props;

// Get current language for generic UI labels
const currentPath = Astro.url.pathname;
const lang = (Astro.currentLocale || (currentPath.startsWith('/en') ? 'en' : defaultLang)) as keyof typeof ui;

function t(key: keyof typeof ui[typeof lang]) {
  return ui[lang][key];
}
---

<BaseLayout title={title}>
  <div class="bg-[#FFFDFA] flex-grow pt-32 pb-24 px-6 font-zain overflow-hidden relative">
    
    <!-- Background decorative blur -->
    <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-[#E8FAF9] rounded-full blur-3xl opacity-60 -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>

    <div class="max-w-6xl mx-auto relative z-10">
      
      <!-- Back Button -->
      <!-- If you have a translation for 'Back to Destinations', you can replace the text below with {t('labels.back')} -->
      <a href={`/${lang}/destinations`} class="inline-flex items-center text-[#1CABB0] hover:text-[#4ED2CE] font-bold mb-10 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Destinations
      </a>

      <!-- 2-Column Grid Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        
        <!-- LEFT COLUMN: Text & Icons -->
        <div class="flex flex-col">
          <h1 class="font-libre text-5xl md:text-6xl font-semibold text-gray-900 mb-6 leading-tight">
            {title}
          </h1>
          
          <p class="text-lg md:text-xl text-gray-600 leading-relaxed mb-10">
            {description}
          </p>

          <!-- Quick Facts -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 bg-white p-6 md:p-8 rounded-3xl shadow-sm border border-gray-100">
            
            <!-- Capital -->
            <div class="flex flex-col items-center sm:items-start text-center sm:text-left">
              <div class="w-12 h-12 bg-[#E8FAF9] text-[#1CABB0] rounded-full flex items-center justify-center mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <span class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-1">{t('labels.capital')}</span>
              <span class="text-gray-900 font-bold text-lg">{capital}</span>
            </div>

            <!-- Language -->
            <div class="flex flex-col items-center sm:items-start text-center sm:text-left">
              <div class="w-12 h-12 bg-[#E8FAF9] text-[#1CABB0] rounded-full flex items-center justify-center mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
                </svg>
              </div>
              <span class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-1">{t('labels.language')}</span>
              <span class="text-gray-900 font-bold text-lg">{language}</span>
            </div>

            <!-- Currency -->
            <div class="flex flex-col items-center sm:items-start text-center sm:text-left">
              <div class="w-12 h-12 bg-[#E8FAF9] text-[#1CABB0] rounded-full flex items-center justify-center mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <span class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-1">{t('labels.currency')}</span>
              <span class="text-gray-900 font-bold text-lg">{currency}</span>
            </div>

          </div>
        </div>

        <!-- RIGHT COLUMN: Bubble Card Image -->
        <div class="relative w-full aspect-[4/5] max-w-[500px] mx-auto lg:ml-auto">
          <!-- Offset decoration blob -->
          <div class="absolute inset-0 bg-[#4ED2CE] rounded-[3rem] translate-x-4 translate-y-4 lg:translate-x-6 lg:translate-y-6 opacity-50"></div>
          
          <!-- Image Wrapper -->
          <div class="absolute inset-0 rounded-[3rem] overflow-hidden shadow-2xl border-[6px] border-white z-10 bg-gray-200">
            <img 
              src={imageSrc} 
              alt={imageAlt} 
              class="w-full h-full object-cover"
            />
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- This slot allows us to inject the correct Carousel at the bottom of the page -->
  <slot />

  <CTAButtons planUrl={planUrl} guideUrl={guideUrl} />


</BaseLayout>