---
// src/components/ui/TravelAdviceContent.astro
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ui, defaultLang } from '../../../i18n/ui';
import TravelAdviceSteps from "./TravelAdviceSteps.astro";

const lang = Astro.currentLocale || defaultLang;

function t(key: string) {
  const dict = ui[lang as keyof typeof ui] as Record<string, string>;
  return dict[key] ?? key;
}
---

  <!-- HERO -->
  <section class="relative w-full h-[100svh] overflow-hidden">

    <!-- IMAGE -->
    <img
      src="/images/travel-plan/sydney.jpg"
      alt="Travel hero"
      class="absolute inset-0 w-full h-full object-cover"
    />

    <!-- DARK OVERLAY -->
    <div class="absolute inset-0 bg-black/40"></div>

    <!-- CONTENT -->
    <div class="relative z-10 h-full flex items-center justify-center px-6">

      <div class="text-center text-white max-w-3xl">

        <!-- TITLE -->
        <h1 class="flex flex-col leading-[0.85] tracking-tight">

          <span class="text-xl md:text-4xl font-medium">
            Persoonlijk reisplan
          </span>

          <span class="text-4xl md:text-7xl font-semibold mt-2">
            Fiji
          </span>

        </h1>

        <!-- CTA BUTTONS -->
        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">

          <a
            href="/route-planner"
            class="bg-[#1CABB0] text-white px-8 py-3 rounded-full font-semibold hover:scale-105 transition"
          >
            Start jouw reis
          </a>

          <a
            href="#features"
            class="border border-white/60 text-white px-8 py-3 rounded-full font-semibold hover:bg-white/10 transition"
          >
            Bekijk details
          </a>

        </div>

      </div>

    </div>

    <!-- LOCATION BADGE (LEFT BOTTOM) -->
    <div class="absolute bottom-6 left-6 z-20 flex items-center gap-2 rounded-full bg-black/40 px-4 py-2 text-white backdrop-blur">

      <!-- ICON -->
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
        <circle cx="12" cy="10" r="3"></circle>
      </svg>

      <span class="uppercase text-xs tracking-wide">
        Australië · Sydney
      </span>

    </div>

  </section>

