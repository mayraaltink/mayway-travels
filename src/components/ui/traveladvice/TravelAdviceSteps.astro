---
import { ui, defaultLang } from '../../../i18n/ui';

const lang = Astro.currentLocale || defaultLang;

function t(key: string) {
  const dict = ui[lang as keyof typeof ui] as Record<string, string>;
  return dict[key] ?? key;
}

const steps = [
  {
    title: 'travelAdvice.steps.step1.title',
    text: 'travelAdvice.steps.step1.text'
  },
  {
    title: 'travelAdvice.steps.step2.title',
    text: 'travelAdvice.steps.step2.text'
  },
  {
    title: 'travelAdvice.steps.step3.title',
    text: 'travelAdvice.steps.step3.text'
  },
  {
    title: 'travelAdvice.steps.step4.title',
    text: 'travelAdvice.steps.step4.text'
  }
];
---

<section class="bg-[#FFFDFA] py-16 md:py-24">
  <div class="mx-auto max-w-6xl px-6">

    <!-- HEADER -->
    <div class="text-center max-w-2xl mx-auto mb-14">
      <h2 class="font-libre text-3xl md:text-4xl font-bold text-gray-900">
        {t('travelAdvice.steps.title')}
      </h2>
      <p class="mt-4 text-gray-600 text-lg">
        {t('travelAdvice.steps.desc')}
      </p>
    </div>

    <!-- GRID -->
    <div class="grid gap-6 md:grid-cols-2">

      {steps.map((step, index) => (
        <div class="group relative rounded-3xl border border-[#E6F6F6] bg-white p-7 shadow-sm transition-all duration-300 hover:shadow-lg hover:-translate-y-1">

          <!-- accent line -->
          <div class="absolute left-0 top-0 h-full w-1 rounded-l-3xl bg-[#4ED2CE]/40 group-hover:bg-[#1CABB0] transition"></div>

          <div class="flex gap-5">

            <!-- number -->
            <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-2xl bg-[#E6F6F6] text-[#1CABB0] font-bold text-lg">
              {index + 1}
            </div>

            <!-- content -->
            <div>
              <p class="text-xs font-bold uppercase tracking-wider text-[#4ED2CE]">
                Stap {index + 1}
              </p>

              <h3 class="mt-1 text-lg font-semibold text-gray-900">
                {t(step.title)}
              </h3>

              <p class="mt-3 text-gray-600 leading-relaxed">
                {t(step.text)}
              </p>
            </div>

          </div>
        </div>
      ))}

    </div>

  </div>
</section>