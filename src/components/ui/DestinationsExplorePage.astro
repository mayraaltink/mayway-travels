---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ui, defaultLang } from '../../i18n/ui';
import WorldMap from '../../components/ui/WorldMap.astro';
import DestinationsGrid from '../../components/ui/DestinationsGrid.astro';

const lang = Astro.currentLocale || defaultLang;

function t(key: keyof typeof ui[typeof defaultLang]) {
  return ui[lang as keyof typeof ui][key];
}

// Data for our markers (Positions are relative percentages based on the SVG map below)
const destinations = [
{
  id: 'fiji',
  top: '70%',
  left: '96%',
  name: t('destinations.fiji.name'),
  desc: t('destinations.fiji.desc'),
  img: '/images/fiji/fiji_main.webp'
},
  {
    id: 'australia',
    top: '76%', 
    left: '83%',
    name: t('destinations.aus.name'),
    desc: t('destinations.aus.desc'),
    img: '/images/australia/aus_main.jpg'
  },
  {
    id: 'new-zealand',
    top: '86%', 
    left: '93%',
    name: t('destinations.nz.name'),
    desc: t('destinations.nz.desc'),
    img: '/images/new-zealand/nz_main.webp'
  }
].sort((a, b) => a.name.localeCompare(b.name));
---

<BaseLayout title={t('destinations.title')}>
<div class="bg-[#4CC2BF] relative z-0 flex-grow pt-16 md:pt-36 pb-2 px-6 overflow-hidden font-zain rounded-b-[60px]">
    
  

    <!-- Map Container -->
    <div class="max-[499px]:hidden w-full mx-auto overflow-x-auto pb-10 hide-scrollbar cursor-grab active:cursor-grabbing">
      <div class="relative w-full max-w-[1400px] mx-auto aspect-[2000/857] min-w-[450px]">
        
        <WorldMap class="absolute inset-0 w-full h-full text-[#E8FAF9]" />

        <!-- Loop over our destinations to render the markers and hover cards -->
        {destinations.map(dest => (
          <!-- Added 'map-marker' to target via JS -->
          <div 
            class="absolute group cursor-pointer map-marker" 
            style={`top: ${dest.top}; left: ${dest.left}; transform: translate(-50%, -50%); z-index: 10;`}
          >
            <!-- Pulse Animation Background (Swapped group-hover for group-[.is-active]) -->
            <div class="absolute inset-0 bg-[#4ED2CE] rounded-full animate-ping opacity-75 group-[.is-active]:hidden"></div>
            
            <!-- Map Marker Pin -->
            <div class="relative flex items-center justify-center w-8 h-8 bg-[#11888c] border-[3px] border-white rounded-full shadow-lg group-[.is-active]:bg-[#4ED2CE] transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>

            <!-- Invisible Hover bridge -->
            <div class="absolute left-1/2 -translate-x-1/2 bottom-full w-64 h-6"></div>

            <!-- Bubble Card (Swapped group-hover for group-[.is-active]) -->
            <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-4 w-64 bg-white rounded-2xl shadow-xl border border-gray-100 opacity-0 scale-95 pointer-events-none group-[.is-active]:opacity-100 group-[.is-active]:scale-100 group-[.is-active]:pointer-events-auto transition-all duration-300 origin-bottom flex flex-col overflow-hidden">
              <div class="absolute -bottom-2 left-1/2 -translate-x-1/2 w-4 h-4 bg-white border-b border-r border-gray-100 rotate-45"></div>
              
              <div class="h-32 w-full overflow-hidden">
                <img src={dest.img} alt={dest.name} class="w-full h-full object-cover" />
              </div>
              
              <div class="p-4 relative bg-white">
                <h3 class="font-bold text-gray-900 text-lg mb-1">{dest.name}</h3>
                <p class="text-sm text-gray-600 mb-4 line-clamp-3 leading-relaxed">
                  {dest.desc}
                </p>
                <a href={`/${lang}/destinations/${dest.id}`} class="block text-center w-full bg-[#4ED2CE] hover:bg-[#1CABB0] text-white py-2 rounded-xl font-bold text-sm transition-colors">
                  {t('destinations.btn')}
                </a>
              </div>
            </div>

          </div>
        ))}

      </div>
    </div>
      </div>
</section> 

    <DestinationsGrid destinations={destinations} />

  </div>
</BaseLayout>

<script>
  // Script block to handle hover, click, and tap cleanly
  let activeMarker: Element | null = null;

  function closeActive() {
    if (activeMarker) {
      activeMarker.classList.remove('is-active');
      activeMarker = null;
    }
  }

  function initMapInteraction() {
    const markers = document.querySelectorAll('.map-marker');

    const openMarker = (marker: Element) => {
      if (activeMarker === marker) return;
      closeActive(); // Guarantees only one shows at a time
      marker.classList.add('is-active');
      activeMarker = marker;
    };

    markers.forEach(marker => {
      // Desktop Hover behavior
      marker.addEventListener('mouseenter', () => openMarker(marker));
      marker.addEventListener('mouseleave', () => closeActive());

      // Mobile Tap/Click behavior
      marker.addEventListener('click', (e) => {
        // Stops the click from hitting the document and instantly closing
        e.stopPropagation();
        
        // Don't intercept clicks if the user clicks the destination link inside the card
        if ((e.target as HTMLElement).closest('a')) return;
        
        openMarker(marker);
      });
    });

    // Close any active card when clicking anywhere else on the map/page
    document.removeEventListener('click', closeActive);
    document.addEventListener('click', closeActive);
  }

  // Initialize on load
  initMapInteraction();

  // Re-run if Astro View Transitions is being used in the project
  document.addEventListener('astro:after-swap', initMapInteraction);
</script>

<style>
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>