---
import { useTranslations } from '../../i18n/ui';

const { lang = 'nl' } = Astro.props;
const t = useTranslations(lang);
---

<section class="relative w-full h-[55vh] md:h-[70vh] overflow-hidden my-20">

  <!-- Background -->
  <div class="absolute inset-0 overflow-hidden rounded-[0px] md:rounded-[40px]">

    <img
      src="/images/Highlight/working-holiday.avif"
      alt="Working Holiday Australia"
      class="w-full h-full object-cover scale-105"
    />

    <!-- Overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/40 to-black/10"></div>

  </div>

  <!-- Content -->
  <div class="relative z-10 flex h-full items-center justify-center text-center px-6">

    <div class="max-w-3xl text-white -translate-y-5">

      <span class="uppercase tracking-[0.25em] text-sm font-medium text-white/80">
        {t('workingholiday.highlight')}
      </span>

      <h2 class="mt-4 mb-6 leading-[0.95] tracking-[-0.03em]">

        <span class="block text-2xl md:text-4xl font-bold medium">
          {t('workingholiday.title')}
        </span>

      </h2>

      <p class="text-base md:text-s leading-8 text-white/90 max-w-2xl mx-auto mb-8">
        {t('workingholiday.description')}
      </p>

      <a
        href={`/${lang}/traveladvice/australia#working-holiday`}
        class="inline-flex items-center gap-2 rounded-full border border-white/30 bg-white/10 backdrop-blur-md px-8 py-3 text-sm font-semibold text-white transition hover:bg-white/20"
      >
        {t('workingholiday.button')}

        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>

      </a>

    </div>

  </div>

</section>